generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  KASIR
}

enum PaymentMethod {
  CASH
  QRIS
  DEBIT
}

model Tenant {
  id           String            @id @default(uuid()) @db.Uuid
  name         String
  slug         String            @unique
  customDomain String?           @unique @map("custom_domain")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  users        User[]
  products     Product[]
  transactions Transaction[]
  items        TransactionItem[]

  @@map("tenants")
}

model User {
  // Use the UUID from Supabase auth.users as this primary key.
  id           String        @id @db.Uuid
  name         String
  email        String        @unique
  role         Role          @default(KASIR)
  isActive     Boolean       @default(true) @map("is_active")
  tenantId     String        @map("tenant_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([tenantId])
  @@unique([tenantId, id])
  @@map("users")
}

model Product {
  id        String            @id @default(uuid()) @db.Uuid
  name      String
  price     Decimal           @db.Decimal(12, 2)
  stock     Int               @default(0)
  tenantId  String            @map("tenant_id") @db.Uuid
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     TransactionItem[]

  @@unique([tenantId, id])
  @@index([tenantId, name])
  @@map("products")
}

model Transaction {
  id            String            @id @default(uuid()) @db.Uuid
  totalAmount   Decimal           @map("total_amount") @db.Decimal(12, 2)
  paymentMethod PaymentMethod     @map("payment_method")
  userId        String            @map("user_id") @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [tenantId, userId], references: [tenantId, id])
  items         TransactionItem[]

  @@unique([tenantId, id])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(uuid()) @db.Uuid
  transactionId String      @map("transaction_id") @db.Uuid
  productId     String      @map("product_id") @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  quantity      Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(12, 2)
  lineTotal     Decimal     @map("line_total") @db.Decimal(12, 2)
  transaction   Transaction @relation(fields: [tenantId, transactionId], references: [tenantId, id], onDelete: Cascade)
  product       Product     @relation(fields: [tenantId, productId], references: [tenantId, id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, transactionId])
  @@index([tenantId, productId])
  @@map("transaction_items")
}
